{
  "name": "@vizdiff/cli",
  "version": "0.0.0",
  "description": "Command-line interface for VizDiff — fast, streamlined screenshot-diff testing for Storybook projects.",
  "keywords": [
    "visual-regression",
    "screenshot",
    "storybook",
    "testing",
    "cli",
    "vizdiff",
    "chromatic",
    "webdriver"
  ],
  "homepage": "https://vizdiff.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vizdiff-io/cli.git"
  },
  "bugs": {
    "url": "https://github.com/vizdiff-io/cli/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ada Pixel",
    "email": "ada@vizdiff.io",
    "url": "https://vizdiff.io"
  },
  "packageManager": "yarn@4.9.1",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "vizdiff": "dist/bin/vizdiff.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint src",
    "prepack": "yarn build",
    "prepublishOnly": "yarn lint && yarn test",
    "start": "ts-node src/bin/vizdiff.ts",
    "test": "yarn run vitest --run",
    "upload": "yarn start upload",
    "vizdiff": "yarn start"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "2.0.0",
    "@semantic-release/changelog": "6.0.3",
    "@types/node": "24.9.1",
    "@typescript-eslint/eslint-plugin": "8.31.0",
    "@typescript-eslint/parser": "8.31.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.2",
    "eslint-plugin-es": "4.1.0",
    "eslint-plugin-filenames": "1.3.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "prettier": "3.8.4",
    "semantic-release": "25.0.5",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "commander": "13.1.0",
    "simple-git": "3.36.0",
    "tslib": "^2.8.1",
    "undici": "7.8.0",
    "zip-a-folder": "6.1.1"
  }
}
